# =============================================================================
# daily-brief — environment configuration
# =============================================================================
# Copy this file to .env.local and edit. .env.local is gitignored, so your
# keys never leave the machine. Leave everything commented to get the
# default behaviour (claude-cli backend, Max subscription billing).

# -----------------------------------------------------------------------------
# LLM backend selector  (default: claude-cli)
# -----------------------------------------------------------------------------
# claude-cli   — spawn local `claude` binary, billed against Max subscription
# anthropic    — Anthropic Messages API, billed per token
# openai       — OpenAI Chat Completions, billed per token
# deepseek     — DeepSeek (OpenAI-compatible), billed per token
# minimax      — MiniMax (OpenAI-compatible), billed per token
# LLM_BACKEND=claude-cli

# Universal model override. If set, applies to whatever backend is active.
# Otherwise each backend uses a sensible default (see below).
# LLM_MODEL=

# Universal API-key & base-URL aliases. The provider-specific env vars below
# (OPENAI_API_KEY / ANTHROPIC_BASE_URL / ...) win when set; these are the
# fallback for pointing at an OpenAI/Anthropic-compatible service that
# isn't one of the named presets — Moonshot, SiliconFlow, OpenRouter,
# self-hosted vLLM, etc. With these you don't have to misuse OPENAI_API_KEY
# just because you're calling a non-OpenAI service.
# LLM_API_KEY=
# LLM_BASE_URL=

# -----------------------------------------------------------------------------
# Backend: claude-cli  (default; uses your local Claude Code login)
# -----------------------------------------------------------------------------
# CLAUDE_CLI_PATH=          # auto-detected from %APPDATA%\npm\claude.cmd or $PATH
# CLAUDE_MODEL=sonnet       # `sonnet` / `opus` / `haiku` etc — passed to --model

# -----------------------------------------------------------------------------
# Backend: anthropic  (Anthropic API key)
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=       # optional; for self-hosted proxies
# LLM_MODEL=claude-sonnet-4-6     # default if not set

# -----------------------------------------------------------------------------
# Backend: openai
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=          # default: https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini     # default if not set

# -----------------------------------------------------------------------------
# Backend: deepseek  (OpenAI-compatible)
# -----------------------------------------------------------------------------
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=        # default: https://api.deepseek.com/v1
# LLM_MODEL=deepseek-v4-flash     # default if not set
#                                  # Note: legacy `deepseek-chat` alias is
#                                  # being retired 2026-07-24, avoid it.

# -----------------------------------------------------------------------------
# Backend: minimax  (OpenAI-compatible)
# -----------------------------------------------------------------------------
# MINIMAX_API_KEY=...
# MINIMAX_BASE_URL=         # default: https://api.minimax.io/v1
#                           # China mainland: https://api.minimaxi.com/v1
# LLM_MODEL=MiniMax-M2.7    # default if not set

# =============================================================================
# Report locale (zh = Chinese, en = English). Default zh.
# =============================================================================
# Switches the full pipeline to the target language:
#   - Source set:    sources.config.json filtered by each source's `locales`
#                    (zh-only V2EX/LinuxDo dropped in en mode, en-only HN/Reddit
#                    picked up — run `npm run sources` to inspect)
#   - LLM prompts:   enrichment + digest + trading commentary all use en prompts
#   - UI:            tab labels / dates / footer / trading widgets all localized
#   - Community tab: auto-hidden in en mode (no community sources qualify)
#
# REPORT_LOCALE=zh

# =============================================================================
# Report timezone (IANA name)
# =============================================================================
# Used for date-keyed filenames (daily_reports/<YYYY-MM-DD>/) and for the
# date labels rendered in the HTML. Defaults to the system local timezone.
# Set this if you want the report's "today" to follow a specific city, e.g.
# you run a server in UTC but read reports in Shanghai time.
#
# Examples: Asia/Shanghai · UTC · America/Los_Angeles · Europe/Berlin
# REPORT_TZ=Asia/Shanghai

# =============================================================================
# Output formats
# =============================================================================
# `daily_reports/<date>/<date>.html` is always written (the deliverable).
# `<date>.json` + `<date>-articles.json` are always written too (functional
# caches needed by `npm run render` / `regen-trading` / `regen-enrich`).
#
# Markdown export is OFF by default — it's a pure archive copy, no script reads
# it. Set this to "true" if you want a plain-text snapshot for grep/archive.
#
# OUTPUT_MARKDOWN=true

# =============================================================================
# Optional: auto-deploy to your own server (after each successful daily run)
# =============================================================================
# If both DEPLOY_HOST and DEPLOY_PATH are set, run-daily.mjs scp+ssh's the
# fresh <date>.html into DEPLOY_PATH and refreshes index.html. The server
# user must have sudo NOPASSWD because the doc root is owned by www-data.
# Leave unset to skip deployment (default).
#
# DEPLOY_HOST=ubuntu@1.2.3.4
# DEPLOY_PATH=/var/www/daily.example.com
